# ========================================
# 安全同步（默认忽略全部，仅白名单放行）
# 目标：上传代码/文档/小体量数据，屏蔽训练产物与大文件
# ========================================

# 默认忽略全部
/*

# 允许核心代码与文档
!/src/
!/src/**
!/scripts/
!/scripts/**
!/data/
!/data/**
!/reports/
!/reports/**

# 允许根目录必要文件
!.gitignore
!README.md
!requirements_dfu.txt
!environment_dfu.yml

# 明确屏蔽大产物目录
/models/
/checkpoints*/
/dfu_checkpoints*/
/retrain_checkpoints*/
/artifacts/
/logs/
/cache/
/.codegraph/
/figures/
/plots/
/draw/
/final-figure/
/lora_ratio_sweep_*/
/dfu_*/
/external/
/md/

# 通用二进制/缓存/临时
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.so
**/*.egg-info/
**/*.swp
**/*.swo
**/*.log
**/*.pt
**/*.bin
**/*.safetensors
**/*.npy
